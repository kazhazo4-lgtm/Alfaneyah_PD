@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alfaneyah - Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/alfaneyah-theme.css" asp-append-version="true" />
    <!-- Inline fallback styles in case CSS doesn't apply -->
    <style>
        /* Critical styles to ensure login page looks correct */
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            background: linear-gradient(135deg, #f5f5f5 0%, #e5e5e5 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(195, 39, 44, 0.15);
            overflow: hidden;
            width: 420px;
            max-width: 100%;
        }

        .login-header {
            background: #174075;
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .logo-wrapper {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }

        .company-logo {
            width: 100px;
            height: 100px;
            object-fit: contain;
            background: white;
            border-radius: 50px;
            padding: 15px;
        }

        .login-header h2 {
            margin: 0;
            font-size: 2rem;
        }

        .login-body {
            padding: 40px 30px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 500;
            color: #174075;
            margin-bottom: 8px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            box-sizing: border-box;
        }

        .btn-login {
            background: #c3272c;
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            padding: 14px;
            width: 100%;
            font-size: 1rem;
            cursor: pointer;
        }

            .btn-login:hover {
                background: #a02024;
            }

        .demo-credentials {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            margin-top: 20px;
        }

        .remember-me {
            margin: 20px 0;
        }

        .footer-text {
            text-align: center;
            margin-top: 25px;
            color: #9b9d9f;
        }
    </style>
</head>
<body class="login-page">
    <div class="login-container">
        <div class="login-header">
            <div class="logo-wrapper">
                <img src="~/images/Original Alfaneyah Logo JPEG.jpeg" alt="Alfaneyah" class="company-logo" />
            </div>
            <h2>Alfaneyah</h2>
            <p>Sign in to your account</p>
        </div>
        <div class="login-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }

            <form method="post">
                <div class="form-group">
                    <label for="username" class="form-label">User Name</label>
                    <input class="form-control" id="username" name="username" placeholder="User Name..." required autofocus>
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="footer-text">
                <i class="bi bi-c-circle me-1"></i> @DateTime.Now.Year Alfaneyah. All rights reserved.
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html> 