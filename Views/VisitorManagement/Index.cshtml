@model ProjectsDashboards.Controllers.VisitorManagementViewModel

@{
    ViewData["Title"] = "Visitor Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">
        <i class="fas fa-shield-alt me-2" style="color: #ef4444;"></i>
        Visitor Management & Security
    </h1>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 4px solid #ef4444;">
                <div class="stat-value text-danger">@Model.TotalRedFlags</div>
                <div class="stat-label">Red Flags</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 4px solid #f59e0b;">
                <div class="stat-value text-warning">@Model.TotalFailedAttempts</div>
                <div class="stat-label">Failed Attempts (7 days)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 4px solid #6b7280;">
                <div class="stat-value">@Model.TotalBlocked</div>
                <div class="stat-label">Blocked Visitors</div>
            </div>
        </div>
    </div>

    <!-- Flagged Visitors Section -->
    <div class="chart-container mb-4">
        <h5 class="chart-title">
            <i class="fas fa-flag text-danger me-2"></i>
            Flagged Visitors (Red Flag)
        </h5>
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Email/Name</th>
                        <th>IP Address</th>
                        <th>Attempt Time</th>
                        <th>Failed Attempts</th>
                        <th>Flag Reason</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var visitor in Model.FlaggedVisitors ?? new List<LoginAttempt>())
                    {
                        <tr class="table-danger">
                            <td><strong>@visitor.EmailOrName</strong></td>
                            <td>@visitor.IPAddress</td>
                            <td>@visitor.AttemptTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@visitor.AttemptCount</td>
                            <td>@visitor.Notes</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#approveModal"
                                        data-attemptid="@visitor.Id" data-email="@visitor.EmailOrName">
                                    <i class="fas fa-check"></i> Approve & Create User
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#blockModal"
                                        data-email="@visitor.EmailOrName">
                                    <i class="fas fa-ban"></i> Block
                                </button>
                                <form asp-action="RemoveRedFlag" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="attemptId" value="@visitor.Id" />
                                    <button type="submit" class="btn btn-sm btn-secondary">
                                        <i class="fas fa-flag-checkered"></i> Remove Flag
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.FlaggedVisitors.Any())
            {
                <div class="text-center text-muted py-3">No flagged visitors</div>
            }
        </div>
    </div>

    <!-- Blocked Visitors Section -->
    <div class="chart-container mb-4">
        <h5 class="chart-title">
            <i class="fas fa-ban me-2" style="color: #6b7280;"></i>
            Blocked Visitors
        </h5>
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Email/Name</th>
                        <th>Blocked At</th>
                        <th>Blocked By</th>
                        <th>Reason</th>
                        <th>Expires</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var blocked in Model.BlockedVisitors ?? new List<BlockedVisitor>())
                    {
                        <tr>
                            <td>@blocked.EmailOrName</td>
                            <td>@blocked.BlockedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(blocked.BlockedByUser?.FullName ?? "Owner")</td>
                            <td>@blocked.Reason</td>
                            <td>
                                @if (blocked.IsPermanent)
                                {
                                    <span class="badge bg-danger">Permanent</span>
                                }
                                else
                                {
                                    <span>@(blocked.BlockedUntil?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                                }
                            </td>
                            <td>
                                <form asp-action="UnblockVisitor" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="blockId" value="@blocked.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fas fa-unlock"></i> Unblock
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.BlockedVisitors.Any())
            {
                <div class="text-center text-muted py-3">No blocked visitors</div>
            }
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ApproveAndCreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Approve Visitor & Create User</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="attemptId" id="attemptId" />
                    <div class="mb-3">
                        <label class="form-label">Email/Name</label>
                        <input type="text" id="emailName" name="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="fullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="role" class="form-select" required>
                            <option value="Staff">Staff</option>
                            <option value="Accountant">Accountant</option>
                            <option value="Owner">Owner</option>
                        </select>
                    </div>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> A temporary password will be generated automatically.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Approve & Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Block Modal -->
<div class="modal fade" id="blockModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="BlockVisitor" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Block Visitor</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="emailOrName" id="blockEmail" />
                    <div class="mb-3">
                        <label class="form-label">Reason for blocking</label>
                        <textarea name="reason" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="isPermanent" id="permanentBlock" value="true" checked>
                            <label class="form-check-label" for="permanentBlock">
                                Permanent Block
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="isPermanent" id="temporaryBlock" value="false">
                            <label class="form-check-label" for="temporaryBlock">
                                Temporary Block
                            </label>
                        </div>
                    </div>
                    <div class="mb-3" id="daysToBlockDiv" style="display:none;">
                        <label class="form-label">Days to block</label>
                        <input type="number" name="daysToBlock" class="form-control" value="30" min="1" max="365" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Block Visitor</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#approveModal').on('show.bs.modal', function(event) {
                var button = $(event.relatedTarget);
                var attemptId = button.data('attemptid');
                var email = button.data('email');
                var modal = $(this);
                modal.find('#attemptId').val(attemptId);
                modal.find('#emailName').val(email);
            });

            $('#blockModal').on('show.bs.modal', function(event) {
                var button = $(event.relatedTarget);
                var email = button.data('email');
                var modal = $(this);
                modal.find('#blockEmail').val(email);
            });

            $('input[name="isPermanent"]').change(function() {
                if ($('#temporaryBlock').is(':checked')) {
                    $('#daysToBlockDiv').show();
                } else {
                    $('#daysToBlockDiv').hide();
                }
            });
        });
    </script>
}