@model ProjectsDashboards.Models.PaymentClaim

@{
    ViewData["Title"] = "Create Payment Claim";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">
        <i class="fas fa-file-invoice me-2" style="color: #10b981;"></i>
        Create Payment Claim
    </h1>

    <div class="chart-container">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ProjectId" class="form-label">Project</label>
                    <select asp-for="ProjectId" class="form-select" asp-items="@(new SelectList(ViewBag.Projects, "Id", "ProjectName"))">
                        <option value="">-- Select Project --</option>
                    </select>
                    <span asp-validation-for="ProjectId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ClaimAmount" class="form-label">Claim Amount (SAR)</label>
                    <div class="input-group">
                        <span class="input-group-text">SAR</span>
                        <input asp-for="ClaimAmount" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="ClaimAmount" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ClaimDate" class="form-label">Claim Date</label>
                    <input asp-for="ClaimDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="ClaimDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="MonthPayment" class="form-label">Month Payment</label>
                    <input asp-for="MonthPayment" class="form-control" placeholder="e.g., January 2024, Q1 2024" />
                    <span asp-validation-for="MonthPayment" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ApprovedDate" class="form-label">Approved Date</label>
                    <input asp-for="ApprovedDate" class="form-control" type="date" />
                    <span asp-validation-for="ApprovedDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="VATDate" class="form-label">VAT Date</label>
                    <input asp-for="VATDate" class="form-control" type="date" />
                    <span asp-validation-for="VATDate" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter claim description..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}