@model ProjectsDashboards.Models.VariationOrder

@{
    ViewData["Title"] = "Delete Variation Order";

    // Determine amount class and sign
    var amountClass = Model.VOAmount > 0 ? "text-success" : Model.VOAmount < 0 ? "text-danger" : "text-muted";
    var amountSign = Model.VOAmount > 0 ? "+" : Model.VOAmount < 0 ? "-" : "";
    var displayAmount = Math.Abs(Model.VOAmount).ToString("N0");
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4 text-danger">Delete Variation Order</h1>

    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this variation order?
    </div>

    <div class="chart-container">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-borderless">
                    <tr>
                        <td style="width: 40%;"><strong>Project:</strong></td>
                        <td>@(Model.Project?.ProjectName ?? "N/A")</td>
                    </tr>
                    <tr>
                        <td><strong>Scope of Work:</strong></td>
                        <td>@(Model.Scope ?? "N/A")</td>
                    </tr>
                    <tr>
                        <td><strong>VO Amount:</strong></td>
                        <td class="fw-bold @amountClass">
                            @amountSign SAR @displayAmount
                            @if (Model.VOAmount > 0)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success ms-2">Increase</span>
                            }
                            else if (Model.VOAmount < 0)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger ms-2">Decrease</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary ms-2">No Change</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Approved Date:</strong></td>
                        <td>@Model.ApprovedDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title text-muted mb-3">Amount Details</h6>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Original Amount:</span>
                            <span class="fw-bold">SAR @displayAmount</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Type:</span>
                            @if (Model.VOAmount > 0)
                            {
                                <span class="badge bg-success">Positive (+) - Addition</span>
                            }
                            else if (Model.VOAmount < 0)
                            {
                                <span class="badge bg-danger">Negative (-) - Deduction</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Zero - No Change</span>
                            }
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Effect on Contract:</span>
                            @if (Model.VOAmount > 0)
                            {
                                <span class="text-success">Increases contract value</span>
                            }
                            else if (Model.VOAmount < 0)
                            {
                                <span class="text-danger">Decreases contract value</span>
                            }
                            else
                            {
                                <span class="text-muted">No effect</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </form>
    </div>
</div>