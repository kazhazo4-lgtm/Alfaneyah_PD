@model ProjectsDashboards.Models.VariationOrder

@{
    ViewData["Title"] = "Create Variation Order";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">Create Variation Order</h1>

    <div class="chart-container">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ProjectId" class="form-label">Project</label>
                    <select asp-for="ProjectId" class="form-select" asp-items="@(new SelectList(ViewBag.Projects, "Id", "ProjectName"))">
                        <option value="">-- Select Project --</option>
                    </select>
                    <span asp-validation-for="ProjectId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="VOAmount" class="form-label">VO Amount (SAR)</label>
                    <input asp-for="VOAmount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="VOAmount" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Scope" class="form-label">Scope of Work</label>
                    <textarea asp-for="Scope" class="form-control" rows="4" placeholder="Describe the scope of this variation order..."></textarea>
                    <span asp-validation-for="Scope" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ApprovedDate" class="form-label">Approved Date</label>
                    <input asp-for="ApprovedDate" class="form-control" type="date" />
                    <span asp-validation-for="ApprovedDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}