@model ProjectsDashboards.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 page-title">@Model.ProjectName</h1>
        <div>
            @if (User.IsInRole("Owner") || User.IsInRole("Staff"))
            {
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Edit
                </a>
            }

            <div class="btn-group ms-2">
                <button type="button" class="btn btn-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-download"></i> Export
                </button>
                <ul class="dropdown-menu">
                    <li>
                        <button class="dropdown-item" onclick="exportToPDF()">
                            <i class="fas fa-file-pdf text-danger"></i> Export as PDF
                        </button>
                    </li>
                    <li>
                        <button class="dropdown-item" onclick="exportToExcel()">
                            <i class="fas fa-file-excel text-success"></i> Export as Excel
                        </button>
                    </li>
                    <li>
                        <button class="dropdown-item" onclick="printProjectDetails()">
                            <i class="fas fa-print text-primary"></i> Print
                        </button>
                    </li>
                </ul>
            </div>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div id="export-content">
        <!-- Project Basic Information -->
        <div class="chart-container">
            <h5 class="chart-title">Basic Information</h5>
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 40%;"><strong>Project Name:</strong></td>
                            <td>@Model.ProjectName</td>
                        </tr>
                        <tr>
                            <td><strong>Project Location:</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.ProjectLocation))
                                {
                                    @Model.ProjectLocation
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Scope of Works:</strong></td>
                            <td>@Model.Scope</td>
                        </tr>
                        <tr>
                            <td><strong>Contract Period:</strong></td>
                            <td>@(Model.ContractStartDate?.ToString("dd/MM/yyyy") ?? "N/A") - @(Model.ContractEndDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                        </tr>
                        <tr>
                            <td><strong>Revised End Date:</strong></td>
                            <td>
                                @if (Model.RevisedEndDate.HasValue)
                                {
                                    @Model.RevisedEndDate.Value.ToString("dd/MM/yyyy")
                                    if (Model.RevisedEndDate > Model.ContractEndDate)
                                    {
                                        <span class="badge">Extended</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not extended</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 40%;"><strong>Contract Value:</strong></td>
                            <td><span class="currency-symbol">SAR</span> @(Model.ContractValue?.ToString("N0") ?? "0")</td>
                        </tr>
                        <tr>
                            <td><strong>Created By:</strong></td>
                            <td>@(Model.CreatedByUser?.FullName ?? "N/A")</td>
                        </tr>
                        <tr>
                            <td><strong>Created At:</strong></td>
                            <td>@(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Payment Claims Section -->
        @if (Model.PaymentClaims != null && Model.PaymentClaims.Any())
        {
            <div class="chart-container">
                <h5 class="chart-title">Payment Claims</h5>
                <div class="table-responsive">
                    <table class="table table-custom" id="paymentClaimsTable">
                        <thead>
                            <tr>
                                <th>MONTH Payment</th>
                                <th>SUBTD Date</th>
                                <th>Claim Amount (SAR)</th>
                                <th>APVD Date</th>
                                <th>VAT Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in Model.PaymentClaims)
                            {
                                <tr>
                                    <td>@claim.MonthPayment</td>
                                    <td>@claim.ClaimDate.ToString("dd/MM/yyyy")</td>
                                    <td>@claim.ClaimAmount.ToString("N0")</td>
                                    <td>@(claim.ApprovedDate.HasValue ? claim.ApprovedDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                    <td>@(claim.VATDate.HasValue ? claim.VATDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td></td>
                                <td><strong>Total Claims:</strong></td>
                                <td><strong>@Model.PaymentClaims.Sum(c => c.ClaimAmount).ToString("N0") SAR</strong></td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="chart-container">
                <h5 class="chart-title">Payment Claims</h5>
                <div class="text-center text-muted py-4">
                    No payment claims found for this project.
                </div>
            </div>
        }

        <!-- Variation Orders Section -->
        @if (Model.VariationOrders != null && Model.VariationOrders.Any())
        {
            <div class="chart-container">
                <h5 class="chart-title">Variation Orders</h5>
                <div class="table-responsive">
                    <table class="table table-custom" id="variationOrdersTable">
                        <thead>
                            <tr>
                                <th>VO Amount (SAR)</th>
                                <th>Approved Date</th>
                                <th>Scope</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vo in Model.VariationOrders)
                            {
                                <tr>
                                    <td>@vo.VOAmount.ToString("N0")</td>
                                    <td>@vo.ApprovedDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(vo.Scope ?? "N/A")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total VOs:</strong></td>
                                <td><strong>@Model.VariationOrders.Sum(vo => vo.VOAmount).ToString("N0") SAR</strong></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="chart-container">
                <h5 class="chart-title">Variation Orders</h5>
                <div class="text-center text-muted py-4">
                    No variation orders found for this project.
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
}