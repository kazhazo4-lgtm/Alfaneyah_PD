@model ProjectsDashboards.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">Create New Project</h1>

    <div class="chart-container">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ProjectName" class="form-label"></label>
                    <input asp-for="ProjectName" class="form-control" />
                    <span asp-validation-for="ProjectName" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ProjectLocation" class="form-label">Project Location</label>
                    <input asp-for="ProjectLocation" class="form-control" placeholder="e.g., Jeddah, Riyadh, Dammam" />
                    <span asp-validation-for="ProjectLocation" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Scope" class="form-label">Scope of Works</label>
                    <textarea asp-for="Scope" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Scope" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="ContractStartDate" class="form-label">Contract Start Date</label>
                    <input asp-for="ContractStartDate" class="form-control" type="date" />
                    <span asp-validation-for="ContractStartDate" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="ContractEndDate" class="form-label">Contract End Date</label>
                    <input asp-for="ContractEndDate" class="form-control" type="date" />
                    <span asp-validation-for="ContractEndDate" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="RevisedEndDate" class="form-label">Revised End Date</label>
                    <input asp-for="RevisedEndDate" class="form-control" type="date" />
                    <span asp-validation-for="RevisedEndDate" class="text-danger"></span>
                    <small class="text-muted">Leave empty if no extension</small>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="ContractValue" class="form-label">
                        <span class="currency-symbol">SAR</span> Contract Value
                    </label>
                    <input asp-for="ContractValue" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ContractValue" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}